---
import Layout from "../layouts/Layout.astro";
import Lightbox from "../components/Lightbox.astro";
import type { ImageMetadata } from "astro";

const all = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/Work2/*.{jpg,JPG,jpeg,png,PNG,gif,GIF,webp}",
  { eager: true },
);

const naturalSort = (a: string, b: string) =>
  a.localeCompare(b, undefined, { numeric: true, sensitivity: "base" });

const images = Object.entries(all)
  .sort(([a], [b]) => naturalSort(a, b))
  .map(([, mod]) => mod.default);
---

<Layout title="Work 02 — Bora Kang" active="work02">
  <section class="px-6 md:px-10 max-w-6xl mx-auto pt-16 pb-24">
    <h2 class="font-serif text-2xl md:text-3xl text-white mb-6">
      UI &amp; Visual Design
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 md:gap-3">
      {images.map((img) => (
        <button
          type="button"
          class="group block w-full overflow-hidden bg-white/5 cursor-pointer"
          data-lightbox
          data-lightbox-group="work02"
          data-lightbox-src={img.src}
          aria-label="Open image"
        >
          <img
            src={img.src}
            width={img.width}
            height={img.height}
            alt=""
            loading="lazy"
            class="w-full h-full object-cover aspect-square transition-transform duration-300 group-hover:scale-[1.02]"
          />
        </button>
      ))}
    </div>
  </section>
  <Lightbox />
</Layout>
