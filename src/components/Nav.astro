---
const { active } = Astro.props as { active?: string };

const links = [
  { href: "/", label: "home" },
  { href: "/work02", label: "work" },
  { href: "/about", label: "about" },
];
---

<nav class="fixed top-3 left-4 z-40 flex gap-3 text-[11px] tracking-wide font-sans">
  {links.map((link) => (
    <a
      href={link.href}
      class:list={[
        "transition-colors hover:text-white",
        active === link.label ? "text-red-500" : "text-white/80",
      ]}
    >
      {link.label}
    </a>
  ))}
</nav>
