---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  images: ImageMetadata[];
  group: string;
  columns?: number;
}

const { images, group, columns = 3 } = Astro.props;

const colClass: Record<number, string> = {
  2: "grid-cols-1 sm:grid-cols-2",
  3: "grid-cols-2 sm:grid-cols-3",
  4: "grid-cols-2 sm:grid-cols-3 md:grid-cols-4",
};
---

<div class={`grid ${colClass[columns] ?? colClass[3]} gap-2 md:gap-3`}>
  {images.map((img) => (
    <button
      type="button"
      class="group block w-full overflow-hidden bg-white/5 cursor-pointer"
      data-lightbox
      data-lightbox-group={group}
      data-lightbox-src={img.src}
      aria-label="Open image"
    >
      <Image
        src={img}
        alt=""
        widths={[400, 800, 1200]}
        sizes="(min-width: 768px) 33vw, 50vw"
        class="w-full h-full object-cover aspect-square transition-transform duration-300 group-hover:scale-[1.02]"
        loading="lazy"
      />
    </button>
  ))}
</div>
