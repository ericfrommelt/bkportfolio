---
import { Image } from "astro:assets";
import chain from "../assets/about/33.png";
---

<section class="px-6 md:px-10 max-w-6xl mx-auto pt-16 md:pt-20">
  <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
    <h1 class="md:col-span-7 font-serif text-white text-[44px] sm:text-6xl md:text-[78px] leading-[1.05] tracking-tight">
      ILLUSTRATOR.<br />MOTION DESIGNER.<br />3D ARTIST.
    </h1>

    <div class="md:col-span-5 md:pt-6 text-[13px] leading-[1.6] text-white/85 font-sans space-y-4">
      <p>
        Bora Kang is an Illustrator, Motion Graphic, and 3D Designer based in
        NYC &amp; LA. Bora has a signature illustrative style that she
        translates uniquely into each project she takes on.
      </p>
      <ul class="space-y-1">
        <li>
          LinkedIn:
          <a
            href="https://linkedin.com/in/borakang/"
            class="underline decoration-white/40 underline-offset-2 hover:decoration-white"
            target="_blank"
            rel="noreferrer"
          >linkedin.com/in/borakang/</a>
        </li>
        <li>
          Mail:
          <a
            href="mailto:hi@borakangwork.com"
            class="underline decoration-white/40 underline-offset-2 hover:decoration-white"
          >hi@borakangwork.com</a>
        </li>
        <li>
          Photography:
          <a
            href="https://vsco.co/borawithfuji/gallery"
            class="underline decoration-white/40 underline-offset-2 hover:decoration-white"
            target="_blank"
            rel="noreferrer"
          >vsco.co/borawithfuji/gallery</a>
        </li>
      </ul>
    </div>
  </div>

  <div class="mt-16 md:mt-24 flex justify-center pb-20">
    <Image
      src={chain}
      alt="Chain illustration"
      class="w-full max-w-3xl h-auto"
      loading="eager"
    />
  </div>
</section>
