---
// Lightbox overlay. Include once per page. Trigger by adding `data-lightbox`
// to any element, with `data-lightbox-src` pointing at the full-size URL
// and `data-lightbox-group` to scope navigation to a set.
---

<div
  id="lightbox"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-black/95 backdrop-blur-sm"
  role="dialog"
  aria-modal="true"
  aria-hidden="true"
>
  <button
    type="button"
    data-lb-close
    aria-label="Close"
    class="absolute top-4 right-5 text-white/80 hover:text-white text-2xl font-sans leading-none cursor-pointer"
  >
    &times;
  </button>

  <button
    type="button"
    data-lb-prev
    aria-label="Previous image"
    class="absolute left-3 md:left-6 top-1/2 -translate-y-1/2 text-white/70 hover:text-white text-3xl font-serif w-12 h-12 flex items-center justify-center cursor-pointer select-none"
  >
    &#8249;
  </button>

  <button
    type="button"
    data-lb-next
    aria-label="Next image"
    class="absolute right-3 md:right-6 top-1/2 -translate-y-1/2 text-white/70 hover:text-white text-3xl font-serif w-12 h-12 flex items-center justify-center cursor-pointer select-none"
  >
    &#8250;
  </button>

  <div
    data-lb-counter
    class="absolute bottom-4 left-1/2 -translate-x-1/2 text-white/60 text-xs font-sans tracking-wide"
  >
  </div>

  <figure class="max-w-[92vw] max-h-[88vh] flex items-center justify-center">
    <img
      data-lb-image
      alt=""
      class="max-w-[92vw] max-h-[88vh] object-contain select-none"
    />
  </figure>
</div>

<script>
  const overlay = document.getElementById("lightbox");
  if (overlay) {
    const imgEl = overlay.querySelector<HTMLImageElement>("[data-lb-image]")!;
    const counterEl = overlay.querySelector<HTMLElement>("[data-lb-counter]")!;
    const prevBtn = overlay.querySelector<HTMLButtonElement>("[data-lb-prev]")!;
    const nextBtn = overlay.querySelector<HTMLButtonElement>("[data-lb-next]")!;
    const closeBtn = overlay.querySelector<HTMLButtonElement>("[data-lb-close]")!;

    type Item = { src: string; alt: string };
    let group: Item[] = [];
    let index = 0;

    const collectGroup = (groupId: string): Item[] => {
      const selector = groupId
        ? `[data-lightbox][data-lightbox-group="${groupId}"]`
        : `[data-lightbox]`;
      return Array.from(document.querySelectorAll<HTMLElement>(selector)).map(
        (el) => {
          const inner = el.querySelector("img");
          return {
            src:
              el.getAttribute("data-lightbox-src") ||
              inner?.getAttribute("src") ||
              "",
            alt: inner?.getAttribute("alt") || "",
          };
        },
      );
    };

    const render = () => {
      const item = group[index];
      if (!item) return;
      imgEl.src = item.src;
      imgEl.alt = item.alt;
      counterEl.textContent = `${index + 1} / ${group.length}`;
      const single = group.length <= 1;
      prevBtn.hidden = single;
      nextBtn.hidden = single;
    };

    const open = (groupId: string, startIndex: number) => {
      group = collectGroup(groupId);
      if (!group.length) return;
      index = Math.max(0, Math.min(startIndex, group.length - 1));
      overlay.classList.remove("hidden");
      overlay.classList.add("flex");
      overlay.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
      render();
    };

    const close = () => {
      overlay.classList.add("hidden");
      overlay.classList.remove("flex");
      overlay.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
      imgEl.src = "";
    };

    const step = (delta: number) => {
      if (!group.length) return;
      index = (index + delta + group.length) % group.length;
      render();
    };

    document.addEventListener("click", (e) => {
      const trigger = (e.target as HTMLElement).closest<HTMLElement>(
        "[data-lightbox]",
      );
      if (!trigger) return;
      e.preventDefault();
      const groupId = trigger.getAttribute("data-lightbox-group") || "";
      const siblings = collectGroup(groupId);
      const src =
        trigger.getAttribute("data-lightbox-src") ||
        trigger.querySelector("img")?.getAttribute("src") ||
        "";
      const start = siblings.findIndex((it) => it.src === src);
      open(groupId, start >= 0 ? start : 0);
    });

    prevBtn.addEventListener("click", () => step(-1));
    nextBtn.addEventListener("click", () => step(1));
    closeBtn.addEventListener("click", close);

    overlay.addEventListener("click", (e) => {
      if (e.target === overlay) close();
    });

    document.addEventListener("keydown", (e) => {
      if (overlay.classList.contains("hidden")) return;
      if (e.key === "Escape") close();
      else if (e.key === "ArrowRight") step(1);
      else if (e.key === "ArrowLeft") step(-1);
    });
  }
</script>
