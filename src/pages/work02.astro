---
export const prerender = true;

import Layout from "../layouts/Layout.astro";
import Gallery from "../components/Gallery.astro";
import Lightbox from "../components/Lightbox.astro";
import type { ImageMetadata } from "astro";

const all = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/Work2/*.{jpg,JPG,jpeg,png,PNG,gif,GIF,webp}",
  { eager: true },
);

const naturalSort = (a: string, b: string) =>
  a.localeCompare(b, undefined, { numeric: true, sensitivity: "base" });

const images = Object.entries(all)
  .sort(([a], [b]) => naturalSort(a, b))
  .map(([, mod]) => mod.default);
---

<Layout title="Work 02 — Bora Kang" active="work02">
  <section class="px-6 md:px-10 max-w-6xl mx-auto pt-16 pb-24">
    <h2 class="font-serif text-2xl md:text-3xl text-white mb-6">
      UI &amp; Visual Design
    </h2>
    <Gallery images={images} group="work02" columns={2} />
  </section>
  <Lightbox />
</Layout>
