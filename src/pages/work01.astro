---
import Layout from "../layouts/Layout.astro";
import Gallery from "../components/Gallery.astro";
import Lightbox from "../components/Lightbox.astro";
import type { ImageMetadata } from "astro";

const all = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/Work1/*.{jpg,JPG,jpeg,png,PNG,gif,GIF,webp}",
  { eager: true },
);

const naturalSort = (a: string, b: string) =>
  a.localeCompare(b, undefined, { numeric: true, sensitivity: "base" });

const images = Object.entries(all)
  .sort(([a], [b]) => naturalSort(a, b))
  .map(([, mod]) => mod.default);

const conceptArts = images.slice(0, 18);
const motionGraphics = images.slice(18, 30);
const etcetera = images.slice(30);
---

<Layout title="Work 01 — Bora Kang" active="work01">
  <section class="px-6 md:px-10 max-w-6xl mx-auto pt-16 pb-24 space-y-16">
    <div>
      <h2 class="font-serif text-2xl md:text-3xl text-white mb-5">
        3D Illustration &amp; Concept Arts
      </h2>
      <Gallery images={conceptArts} group="work01" columns={3} />
    </div>

    {motionGraphics.length > 0 && (
      <div>
        <h2 class="font-serif text-2xl md:text-3xl text-white mb-5">
          3D Illustration &amp; Motion Graphics
        </h2>
        <Gallery images={motionGraphics} group="work01" columns={3} />
      </div>
    )}

    {etcetera.length > 0 && (
      <div>
        <h2 class="font-serif text-2xl md:text-3xl text-white mb-5">
          Etcetera
        </h2>
        <Gallery images={etcetera} group="work01" columns={3} />
      </div>
    )}
  </section>
  <Lightbox />
</Layout>
