---
import Layout from "../layouts/Layout.astro";
import Gallery from "../components/Gallery.astro";
import Lightbox from "../components/Lightbox.astro";
import type { ImageMetadata } from "astro";

const all = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/Work1/*.{jpg,JPG,jpeg,png,PNG,gif,GIF,webp}",
  { eager: true },
);

const naturalSort = (a: string, b: string) =>
  a.localeCompare(b, undefined, { numeric: true, sensitivity: "base" });

const images = Object.entries(all)
  .sort(([a], [b]) => naturalSort(a, b))
  .map(([, mod]) => mod.default);

const conceptArts = images.slice(0, 18);
const motionGraphics = images.slice(18, 30);
const etcetera = images.slice(30);
---

<Layout title="Work 01 — Bora Kang" active="work01">
  <section class="px-6 md:px-10 max-w-6xl mx-auto pt-16 pb-24 space-y-16">
    <header>
      <div class="flex">
        <h2 class="flex-1 font-serif text-1xl md:text-4xl lg:text-5xl text-white mb-5">
          3D Illustration &amp; Concept Art
        </h2>
        <p class="flex-1">3D style illustration and motion graphic videos created with C4D, Octane, Redshift, Marvelous Designer, Procreate, Daz 3D, Z-Brush, and Photoshop.</p>
      </div>
    </header>
    <Gallery images={conceptArts} group="work01" columns={3} />

    {motionGraphics.length > 0 && (
      <header>
        <div class="flex">
          <h2 class="flex-1 font-serif text-1xl md:text-4xl lg:text-5xl text-white mb-5">
            2D Illustration &amp; Motion Graphics
          </h2>
          <p class="flex-1 self-auto">2D style illustration and motion graphic videos with different concepts. Created with Procreate and Illustrator.</p>
        </div>
          <Gallery images={motionGraphics} group="work01" columns={3} />

      </header>
    )}

    {etcetera.length > 0 && (
      <div>
        <h2 class="font-serif text-2xl md:text-3xl text-white mb-5">
          Etcetera
        </h2>
        <Gallery images={etcetera} group="work01" columns={3} />
      </div>
    )}
  </section>
  <Lightbox />
</Layout>
